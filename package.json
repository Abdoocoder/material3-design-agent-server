{
  "name": "material3-design-agent-server",
  "version": "1.0.0",
  "description": "MCP App for reviewing Material 3 UI designs",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"tsx --watch main.ts\"",
    "build": "tsc && vite build",
    "serve": "node dist/main.js",
    "start": "npm run build && npm run serve"
  },
  "keywords": [
    "mcp",
    "material3",
    "design",
    "ui-review"
  ],
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
